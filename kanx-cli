#!/usr/bin/env php
<?php

// Smart Autoload Finder: Searches for vendor/autoload.php in local or parent directories
$autoloadPaths = [
    __DIR__ . '/vendor/autoload.php',           // Local dev
    __DIR__ . '/../../autoload.php',            // Inside vendor/bin (standard)
    __DIR__ . '/../../../vendor/autoload.php',  // Deeper nested
];

$found = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require_once $path;
        $found = true;
        break;
    }
}

if (!$found) {
    die("❌ Error: Could not find vendor/autoload.php. Please run 'composer install'.\n");
}

use KanxPHP\Core\SafeJSON;

/**
 * Kanx-CLI: The RAD Scaffolding Tool for KanxPHP
 */

$command = $argv[1] ?? 'help';
$name = $argv[2] ?? null;

switch ($command) {
    case 'make:controller':
        if (!$name) {
            echo "Usage: php kanx-cli make:controller {Name}\n";
            exit(1);
        }
        createController($name);
        break;

    case 'make:connector':
        // Usage pattern: php kanx-cli make:connector woocommerce shopify
        $source = $argv[2] ?? null;
        $destination = $argv[3] ?? null;
        if (!$source || !$destination) {
            echo "Usage: php kanx-cli make:connector {source} {destination}\n";
            exit(1);
        }
        createConnector($source, $destination);
        break;

    case 'build:kit':
        if (!$name) {
            echo "Usage: php kanx-cli build:kit {niche}\n";
            exit(1);
        }
        buildKit($name);
        break;

    case 'cache:clear':
        $pruneOnly = in_array('--prune', $argv);
        clearCache($pruneOnly);
        break;

    case 'help':
    default:
        echo "KanxPHP CLI v1.1.0\n";
        echo "Available commands:\n";
        echo "  make:controller {Name}             - Generate a new API controller\n";
        echo "  make:connector {src} {dest}        - Generate DTaaS pipeline connector & schemas\n";
        echo "  build:kit {niche}                  - Scaffold a new niche API bundle\n";
        echo "  cache:clear [--prune]              - Flush internal system cache storage\n";
        break;
}

function clearCache($pruneOnly = false) {
    $cacheDir = __DIR__ . '/storage/cache';
    if (!is_dir($cacheDir)) return;

    $files = glob($cacheDir . '/*.php');
    $deleted = 0;
    $kept = 0;

    foreach ($files as $file) {
        if ($pruneOnly) {
            @include $file; // Injects $expire
            if (isset($expire) && $expire < time()) {
                unlink($file);
                $deleted++;
            } else {
                $kept++;
            }
        } else {
            unlink($file);
            $deleted++;
        }
    }

    $mode = $pruneOnly ? "Pruned (Expired Only)" : "Hard Cleared (All)";
    echo "✅ Cache {$mode}: {$deleted} files removed. {$kept} files remaining.\n";
}

function createController($name) {
    $dir = getcwd() . "/src/Controllers";
    if (!is_dir($dir)) mkdir($dir, 0755, true);

    $path = "{$dir}/{$name}Controller.php";
    if (file_exists($path)) {
        echo "Error: Controller already exists.\n";
        return;
    }

    $template = "<?php\n\nnamespace KanxPHP\Controllers;\n\nuse KanxPHP\Core\SafeJSON;\n\nclass {$name}Controller {\n\n    public function handle(\$input) {\n        // Your RAD logic here\n        return SafeJSON::success(['tool' => '{$name}', 'status' => 'ready']);\n    }\n}\n";
    
    file_put_contents($path, $template);
    echo "✅ Successfully created: src/Controllers/{$name}Controller.php\n";
}

/**
 * NEW: Generates Version-Controlled Stateless Connector Pipelines & JSON Schemas
 */
function createConnector($source, $destination) {
    $source = strtolower($source);
    $destination = strtolower($destination);
    
    $prefixSrc = ucfirst($source);
    $prefixDest = ucfirst($destination);
    $className = "{$prefixSrc}To{$prefixDest}Controller";
    
    $controllerDir = getcwd() . "/src/Controllers";
    $configBaseDir = getcwd() . "/config/connectors";

    // 1. Generate structural data config directory snapshots paths [INDEX]
    $srcConfigDir  = "{$configBaseDir}/{$source}/v1";
    $destConfigDir = "{$configBaseDir}/{$destination}/v1";

    if (!is_dir($controllerDir)) mkdir($controllerDir, 0755, true);
    if (!is_dir($srcConfigDir)) mkdir($srcConfigDir, 0755, true);
    if (!is_dir($destConfigDir)) mkdir($destConfigDir, 0755, true);

    $controllerPath = "{$controllerDir}/{$className}.php";

    if (file_exists($controllerPath)) {
        echo "❌ Error: Connector translation route pipeline already exists.\n";
        return;
    }

    // 2. Draft the universal, parameter-driven pass-through controller template [INDEX]
    $controllerTemplate = "<?php\n\nnamespace KanxPHP\Controllers;\n\nuse KanxPHP\Core\SafeConnector;\nuse KanxPHP\Core\SafeJSON;\n\nclass {$className} {\n\n    /**\n     * Executes high-speed A-to-B data transformation streams via memory registers\n     */\n    public function transformStream(string \$rawInboundPayload, string \$resourceType = 'products'): array {\n        \$configRoot = getcwd() . '/config/connectors';\n        \n        // Resolve documentation schema files rules on the fly\n        \$srcRulesPath  = \"{\$configRoot}/{$source}/v1/transformer_{\$resourceType}.json\";\n        \$destRulesPath = \"{\$configRoot}/{$destination}/v1/push_transformer_{\$resourceType}.json\";\n\n        if (!file_exists(\$srcRulesPath) || !file_exists(\$destRulesPath)) {\n            return ['success' => false, 'error' => 'Configuration schema translation files maps missing.'];\n        }\n\n        \$srcRules  = json_decode(file_get_contents(\$srcRulesPath), true);\n        \$destRules = json_decode(file_get_contents(\$destRulesPath), true);\n\n        // Pass 1: Native Data (A) ➔ Universal Standardised Format [INDEX]\n        \$ipaasStandardArray = SafeConnector::extract(\$rawInboundPayload, \$srcRules);\n\n        // Pass 2: Universal Standardised Format ➔ Target Destination Data (B) [INDEX]\n        \$finalNativePayload = SafeConnector::inject(\$ipaasStandardArray, \$destRules);\n\n        return [\n            'success' => true,\n            'source_platform' => '{$source}',\n            'destination_platform' => '{$destination}',\n            'resource_type' => \$resourceType,\n            'transformed_payload' => \$finalNativePayload\n        ];\n    }\n}\n";

    file_put_contents($controllerPath, $controllerTemplate);

    // 3. Auto-generate declarative Source Input extractor dummy profile dictionary [INDEX]
    $srcDummyTemplate = [
        "standard_id:string"   => "id",
        "standard_title:string" => "name",
        "standard_sku:string"   => "sku",
        "standard_price:float"  => "regular_price",
        "standard_stock:int"    => "stock_quantity"
    ];
    file_put_contents("{$srcConfigDir}/transformer_products.json", json_encode($srcDummyTemplate, JSON_PRETTY_PRINT));

    // 4. Auto-generate declarative Destination Output injector dummy profile dictionary [INDEX]
    $destDummyTemplate = [
        "product.title:string" => "standard_title",
        "product.variants.0.sku:string" => "standard_sku",
        "product.variants.0.price:string" => "standard_price",
        "product.variants.0.inventory_quantity:int" => "standard_stock"
    ];
    file_put_contents("{$destConfigDir}/push_transformer_products.json", json_encode($destDummyTemplate, JSON_PRETTY_PRINT));

    echo "✅ Successfully created DTaaS pipeline connector system:\n";
    echo "  - Controller: src/Controllers/{$className}.php\n";
    echo "  - Source Map:  config/connectors/{$source}/v1/transformer_products.json\n";
    echo "  - Target Map:  config/connectors/{$destination}/v1/push_transformer_products.json\n";
}

function buildKit($kitName) {
    echo "🚀 Building Kit: {$kitName}...\n";

    if (is_dir($kitName)) {
        echo "❌ Error: Directory '{$kitName}' already exists.\n";
        return;
    }
    mkdir($kitName, 0755);

    $folders = [
        "{$kitName}/src/Controllers",
        "{$kitName}/src/Core",
        "{$kitName}/public",
        "{$kitName}/tests"
    ];

    foreach ($folders as $folder) {
        mkdir($folder, 0755, true);
        echo "  - Created {$folder}\n";
    }

    $indexTemplate = "<?php\n\nrequire_once __DIR__ . '/../vendor/autoload.php';\n\n// Basic RAD Router\necho 'Welcome to {$kitName} API';\n";
    file_put_contents("{$kitName}/public/index.php", $indexTemplate);

    $composerData = [
        "name" => "kanxphp/{$kitName}",
        "description" => "A high-performance micro-app kit built with KanxPHP",
        "autoload" => [
            "psr-4" => [
                "KanxPHP\\Controllers\\" => "src/Controllers/",
                "KanxPHP\\Core\\" => "src/Core/"
            ]
        ],
        "require" => [
            "php" => ">=8.1",
            "kanxphp/core" => "dev-main"
        ],
        "scripts" => [
            "kanx" => "php vendor/kanxphp/core/kanx-cli"
        ]
    ];

    file_put_contents(
        "{$kitName}/composer.json", 
        json_encode($composerData, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES)
    );

    $file = __DIR__ . "/./kanx-cli";
    $newfile = "{$kitName}/kanx";

    if (!copy($file, $newfile)) {
        echo "failed to copy $file...\n";
    }

    shell_exec("cd {$kitName} && git init");
    shell_exec("cd {$kitName} && composer install");

    echo "✅ Kit '{$kitName}' is built. \n👉 Next steps: \n   cd {$kitName}\n";
}